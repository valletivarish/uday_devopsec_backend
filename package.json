{
  "name": "backend",
  "version": "1.0.0",
  "description": "Order Processing and Management System - Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage --forceExit --detectOpenHandles",
    "lint": "eslint src/"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.3",
    "pg": "^8.20.0",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "eslint": "^10.1.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "sequelize-cli": "^6.6.5",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/src/__tests__/**/*.test.js"],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
