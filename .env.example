# ============================================================================
# Environment Variables Template - Backend API
#
# Copy this file to .env and fill in the values for your environment.
# NEVER commit the actual .env file to version control.
#
# Author: Uday Kiran Reddy Dodda (x25166484)
# ============================================================================

# Server Configuration
PORT=5000
NODE_ENV=development

# PostgreSQL Database Configuration (use RDS endpoint in production)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=order_processing_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_here

# Email Configuration (simulation mode for development)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=test@ethereal.email
SMTP_PASS=testpassword
